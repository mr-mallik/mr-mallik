# force index loading only
DirectoryIndex index.php

# Enable URL rewriting
RewriteEngine On

# Redirect /projects/{slug} to project-det.php
RewriteRule ^projects/([^/]+)?/?$ pages/project-det.php?slug=$1 [L,QSA]

# Add specific rewrite rules for other pages
RewriteRule ^projects?/?$ pages/project.php [L,QSA]