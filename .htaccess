# force index loading only
DirectoryIndex index.php

# Enable URL rewriting
RewriteEngine On

# Redirect to internal pages
RewriteRule ^projects/([^/]+)?/?$ pages/article.php?type=project&slug=$1 [L,QSA]
RewriteRule ^stories/([^/]+)?/?$ pages/article.php?type=blog&slug=$1 [L,QSA]

# Add specific rewrite rules for other pages
RewriteRule ^projects?/?$ pages/project.php [L,QSA]
RewriteRule ^contact?/?$ pages/contact.php [L,QSA]
RewriteRule ^about?/?$ pages/about.php [L,QSA]
RewriteRule ^stories?/?$ pages/blogs.php [L,QSA]

# Admin module
RewriteRule ^admin/?$ pages/admin/dashboard.php [L,QSA]
RewriteRule ^admin/login/?$ pages/admin/login.php [L,QSA]
RewriteRule ^admin/auth/?$ pages/admin/auth.php [L,QSA]
RewriteRule ^admin/dashboard/?$ pages/admin/dashboard.php [L,QSA]
RewriteRule ^admin/blogs/?$ pages/admin/blogs.php [L,QSA]
RewriteRule ^admin/blog-details/?$ pages/admin/blog-details.php [L,QSA]
RewriteRule ^admin/projects/?$ pages/admin/projects.php [L,QSA]
RewriteRule ^admin/skills/?$ pages/admin/skills.php [L,QSA]
RewriteRule ^admin/resume/?$ pages/admin/resume.php [L,QSA]
RewriteRule ^admin/services/?$ pages/admin/services.php [L,QSA]
RewriteRule ^admin/files/?$ pages/admin/files.php [L,QSA]
RewriteRule ^admin/profile/?$ pages/admin/profile.php [L,QSA]
RewriteRule ^admin/logs/?$ pages/admin/logs.php [L,QSA]
RewriteRule ^admin/logout/?$ pages/admin/logout.php [L,QSA]

# Finance module
RewriteRule ^admin/accounts?/?$ pages/finance/accounts.php [L,QSA]

# Custom error pages
ErrorDocument 401 /errors/401.php
ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
ErrorDocument 500 /errors/500.php
ErrorDocument 502 /errors/502.php
ErrorDocument 503 /errors/503.php