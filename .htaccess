# force index loading only
DirectoryIndex index.php

# Enable URL rewriting
RewriteEngine On

# Redirect to internal pages
RewriteRule ^projects/([^/]+)?/?$ pages/article.php?type=project&slug=$1 [L,QSA]
RewriteRule ^stories/([^/]+)?/?$ pages/article.php?type=blog&slug=$1 [L,QSA]

# Add specific rewrite rules for other pages
RewriteRule ^projects?/?$ pages/project.php [L,QSA]
RewriteRule ^contact?/?$ pages/contact.php [L,QSA]
RewriteRule ^about?/?$ pages/about.php [L,QSA]
RewriteRule ^stories?/?$ pages/blogs.php [L,QSA]

# Finance module
RewriteRule ^finance/accounts?/?$ pages/finance/accounts.php [L,QSA]

# Custom error pages
ErrorDocument 401 /mrmallik/errors/401.php
ErrorDocument 403 /mrmallik/errors/403.php
ErrorDocument 404 /mrmallik/errors/404.php
ErrorDocument 500 /mrmallik/errors/500.php
ErrorDocument 502 /mrmallik/errors/502.php
ErrorDocument 503 /mrmallik/errors/503.php